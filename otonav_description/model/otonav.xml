<!--
  OtoNav differential-drive robot — minimal physics model (Phase 1).
  Deliberately simple: chassis + 2 actuated wheels + frictionless caster,
  an IMU site and a 13-beam forward lidar fan. Physics correctness only;
  no visual polish (CLAUDE.md "What NOT to Do").

  Named entities the bridge maps by name (see mujoco_interface.cpp):
    actuators : left_wheel_act, right_wheel_act   (velocity, ctrl = rad/s)
    sensors   : left_wheel_pos/vel, right_wheel_pos/vel,
                imu_quat, imu_gyro, imu_acc, lidar_0..lidar_12
  Geometry constants must match bridge params: wheel_radius=0.05, track_width=0.30.
-->
<mujoco model="otonav">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.01"/>
    <geom friction="1.0 0.005 0.0001"/>
    <default class="wheel">
      <geom type="cylinder" size="0.05 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1"/>
    </default>
  </default>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="20 20 0.1" rgba="0.8 0.8 0.8 1"/>

    <body name="base_link" pos="0 0 0.05">
      <freejoint name="base_free"/>
      <inertial pos="0 0 0.02" mass="3.0" diaginertia="0.02 0.03 0.04"/>
      <geom name="chassis" type="box" size="0.15 0.10 0.04" pos="0 0 0.04" rgba="0.1 0.4 0.8 1"/>

      <!-- Frictionless caster supports at front AND rear. Two casters give a
           4-point stance so the chassis does not pitch nose-down under
           acceleration — otherwise the front lidar beams tip into the floor
           and false-trigger stop-on-obstacle. -->
      <geom name="caster_rear" type="sphere" size="0.025" pos="-0.12 0 -0.025"
            friction="0.0001 0.0001 0.0001" condim="1" rgba="0.3 0.3 0.3 1"/>
      <geom name="caster_front" type="sphere" size="0.025" pos="0.12 0 -0.025"
            friction="0.0001 0.0001 0.0001" condim="1" rgba="0.3 0.3 0.3 1"/>

      <!-- IMU mounting point -->
      <site name="imu_site" pos="0 0 0.04" size="0.01"/>

      <!-- 13-beam forward lidar fan (-90..90 deg, 15 deg step); zaxis = beam ray -->
      <site name="lidar_0" pos="0.12 0 0.10" zaxis="0.0 -1.0 0"/>
      <site name="lidar_1" pos="0.12 0 0.10" zaxis="0.258819 -0.965926 0"/>
      <site name="lidar_2" pos="0.12 0 0.10" zaxis="0.5 -0.866025 0"/>
      <site name="lidar_3" pos="0.12 0 0.10" zaxis="0.707107 -0.707107 0"/>
      <site name="lidar_4" pos="0.12 0 0.10" zaxis="0.866025 -0.5 0"/>
      <site name="lidar_5" pos="0.12 0 0.10" zaxis="0.965926 -0.258819 0"/>
      <site name="lidar_6" pos="0.12 0 0.10" zaxis="1.0 0.0 0"/>
      <site name="lidar_7" pos="0.12 0 0.10" zaxis="0.965926 0.258819 0"/>
      <site name="lidar_8" pos="0.12 0 0.10" zaxis="0.866025 0.5 0"/>
      <site name="lidar_9" pos="0.12 0 0.10" zaxis="0.707107 0.707107 0"/>
      <site name="lidar_10" pos="0.12 0 0.10" zaxis="0.5 0.866025 0"/>
      <site name="lidar_11" pos="0.12 0 0.10" zaxis="0.258819 0.965926 0"/>
      <site name="lidar_12" pos="0.12 0 0.10" zaxis="0.0 1.0 0"/>

      <body name="left_wheel" pos="0 0.15 0">
        <joint name="left_wheel" type="hinge" axis="0 1 0"/>
        <geom class="wheel"/>
      </body>
      <body name="right_wheel" pos="0 -0.15 0">
        <joint name="right_wheel" type="hinge" axis="0 1 0"/>
        <geom class="wheel"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="left_wheel_act"  joint="left_wheel"  kv="5.0" ctrlrange="-30 30"/>
    <velocity name="right_wheel_act" joint="right_wheel" kv="5.0" ctrlrange="-30 30"/>
  </actuator>

  <sensor>
    <jointpos name="left_wheel_pos"  joint="left_wheel"/>
    <jointvel name="left_wheel_vel"  joint="left_wheel"/>
    <jointpos name="right_wheel_pos" joint="right_wheel"/>
    <jointvel name="right_wheel_vel" joint="right_wheel"/>

    <framequat     name="imu_quat" objtype="site" objname="imu_site"/>
    <gyro          name="imu_gyro" site="imu_site"/>
    <accelerometer name="imu_acc"  site="imu_site"/>

    <rangefinder name="lidar_0"  site="lidar_0"/>
    <rangefinder name="lidar_1"  site="lidar_1"/>
    <rangefinder name="lidar_2"  site="lidar_2"/>
    <rangefinder name="lidar_3"  site="lidar_3"/>
    <rangefinder name="lidar_4"  site="lidar_4"/>
    <rangefinder name="lidar_5"  site="lidar_5"/>
    <rangefinder name="lidar_6"  site="lidar_6"/>
    <rangefinder name="lidar_7"  site="lidar_7"/>
    <rangefinder name="lidar_8"  site="lidar_8"/>
    <rangefinder name="lidar_9"  site="lidar_9"/>
    <rangefinder name="lidar_10" site="lidar_10"/>
    <rangefinder name="lidar_11" site="lidar_11"/>
    <rangefinder name="lidar_12" site="lidar_12"/>
  </sensor>
</mujoco>
