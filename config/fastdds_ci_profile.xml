<?xml version="1.0" encoding="UTF-8"?>
<!--
  FastDDS fallback profile for CI (ADR-3). NOT used by default: the primary
  strategy is ROS_LOCALHOST_ONLY=1 + rmw_fastrtps_cpp, which is sufficient on
  GitHub runners. Reach for this only if loopback discovery demonstrably fails.

  Strategy: UDPv4 transport with unicast metatraffic and initialPeers pinned to
  127.0.0.1, multicast discovery off. Note: a SHM-only transport with builtin
  transports disabled breaks discovery (SHM carries data, discovery still needs
  UDP). SHM may be ADDED alongside UDPv4 for intra-host throughput.

  Use:
    export RMW_IMPLEMENTATION=rmw_fastrtps_cpp
    export FASTRTPS_DEFAULT_PROFILES_FILE=$PWD/config/fastdds_ci_profile.xml
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>udp_loopback</transport_id>
        <type>UDPv4</type>
      </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="ci_loopback" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>udp_loopback</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
        <builtin>
          <metatrafficUnicastLocatorList>
            <locator>
              <udpv4>
                <address>127.0.0.1</address>
              </udpv4>
            </locator>
          </metatrafficUnicastLocatorList>
          <initialPeersList>
            <locator>
              <udpv4>
                <address>127.0.0.1</address>
              </udpv4>
            </locator>
          </initialPeersList>
        </builtin>
      </rtps>
    </participant>
  </profiles>
</dds>
